// 2 - confirmar o total de avaliações inseridas 
db.avaliacoes.countDocuments();
// 3 - atualizar um filme
db.titulos.updateOne(
  { titulo: "Succession" },
  { $set: { "avaliacao.media": 9.7, "avaliacao.total_votos": 480003 } }
);


// Missão 3 — construindo as consultas da plataforma -----------------------------------------------------------
// 3.1 - retornar apenas título, tipo, gêneros e avaliação média de titulos disponíveis em português
db.titulos.find({'catalogo_ativo':true, disponivel_em:'BR'}, {'titulo': 1, 'tipo': 1, 'generos': 1, 'avaliacao.media': 1});

// 3.2 - mostrar titulo, avaliação média e avaliação total de votos de apenas 3 títulos que possuam mais que 60.000 votos de forma decrescente por média
db.titulos.find({'avaliacao.total_votos': {$gt:60000}}, {'titulo': 1, 'avaliacao.media': 1, 'avaliacao.total_votos': 1}).sort({'avaliacao.media': -1}).limit(3);

// 3.3 - retorna titulo, tipo, ano de lançamento e gêneros entre os gêneros de drama e história dos títulos a partir de 2019
db.titulos.find({'generos': {$in: ['drama','historia']}, 'ano_lancamento': {$gte: 2019}}, {'titulo': 1, 'tipo': 1, 'ano_lancamento': 1, 'generos': 1});

// 3.4 - retorna títulos que contém trecho sequencial 'ca' no campo título, sem diferenciar maiúsculas de minúsculas
db.titulos.find({'titulo': {$regex: 'ca', $options: 'i'}});

// 3.5 - buscar entre todos os usuários os que possuem plano premium e estão ativos e retornar o nome, email e país ordenados por nome em ordem asc
db.usuarios.find({'plano': 'premium', 'ativo': true}, {'nome': 1, 'email': 1, 'pais': 1}).sort({'nome': 1});

// 3.6 - um usuário gostaria de assistir uma obra boa e popular da época de 2024, porém está em dúvida e precisa de uma recomendação. Ele confia muito mais nas avaliações dos usuários, portanto, gostaria de lê-las para decidir qual obra assistir. Para não ficar sobrecarregado com uma massa muito grande de informações, procura apenas pelas 3 obras que foram melhores avaliadas. MONTAR UMA QUERY QUE BUSCA AS MELHORES 3 NOTAS E AVALIAÇÕES DOS USUÁRIOS, FILTRANDO O ANO PARA 2024 ENTRE OS REGISTROS E ORGANIZANDO-OS POR NOTA DE FORMA DECRESCENTE.
db.avaliacoes.find({'data_avaliacao': {$gte: '2024-01-01', $lt:'2025-01-01'}}).sort({'nota': -1}).limit(3);

// Missão 4 — gerenciando o catálogo -----------------------------------------------------------
// Tarefa 4.1 - inativar/suspender um título
db.titulos.updateOne({'titulo': 'Caras e Bocas'}, {$set: {'catalogo_ativo': false}});
db.titulos.find({'catalogo_ativo': false});

// Tarefa 4.2 - expandindo a disponibilidade dos titulos
db.titulos.updateOne({'titulo': 'Cangaço Novo'}, {$push: {'disponivel_em': 'MX'}});
db.titulos.updateOne({'titulo': 'Ainda Estou Aqui'}, {$push: {'disponivel_em': 'MX'}});
db.titulos.find({'titulo': 'Cangaço Novo'});
db.titulos.find({'titulo': 'Ainda Estou Aqui'});

// Tarefa 4.3 - encerrando assinaturas inativas !deleção de dados
db.usuarios.find({'ativo': false});
db.usuarios.deleteMany({'ativo': false});
db.usuarios.countDocuments();
