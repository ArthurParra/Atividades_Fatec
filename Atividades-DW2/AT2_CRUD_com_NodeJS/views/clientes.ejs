<%- include ('partials/header.ejs') %>
    <h1>Clientes</h1>
    <hr>
    <div class="mb-3">
        <a href="/clientes/new" class="btn btn-primary">Novo Cliente</a>
        <a href="/" class="btn btn-secondary">Voltar</a>
    </div>

    <h3>Lista de clientes:</h3>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Email</th>
                <th>Telefone</th>
                <th>Endereço</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            <% if (clientes && clientes.length) { %>
                <% clientes.forEach(cliente => { %>
                    <tr>
                        <td><%= cliente.nome %></td>
                        <td><%= cliente.cpf %></td>
                        <td><%= cliente.email || '-' %></td>
                        <td><%= cliente.telefone || '-' %></td>
                        <td><%= cliente.endereco || '-' %></td>
                        <td>
                            <a href="/clientes/<%= cliente.id %>/edit" class="btn btn-sm btn-warning">Editar</a>
                            <form action="/clientes/<%= cliente.id %>/delete" method="post" style="display:inline-block;" onsubmit="return confirm('Confirma exclusão deste cliente?');">
                                <button class="btn btn-sm btn-danger" type="submit">Excluir</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="6">Nenhum cliente cadastrado.</td></tr>
            <% } %>
        </tbody>
    </table>
<%- include ('partials/footer.ejs') %>